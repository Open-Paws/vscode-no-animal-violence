{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"files": {
		"ignore": [".desloppify/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"indentStyle": "tab",
			"lineWidth": 120
		}
	}
}
