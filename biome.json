{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"files": {
		"includes": ["**", "!.desloppify", "!extension.js"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"indentStyle": "tab",
			"lineWidth": 120
		}
	}
}
